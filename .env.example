# ============================================================================
# Plataforma Interna Reboucas e Bulhoes - Variaveis de ambiente
# ============================================================================

# Ambiente
NODE_ENV=production
TZ=America/Bahia
APP_DOMAIN=plataforma.reboucasebulhoes.com.br
APP_URL=https://plataforma.reboucasebulhoes.com.br

# ============================================================================
# Banco de dados PostgreSQL 16
# ============================================================================
POSTGRES_USER=rb_admin
POSTGRES_PASSWORD=SUBSTITUIR_POR_SENHA_FORTE
POSTGRES_DB=rb_plataforma
DATABASE_URL=postgresql://rb_admin:SUBSTITUIR_POR_SENHA_FORTE@db:5432/rb_plataforma?schema=public

# ============================================================================
# Autenticacao
# ============================================================================
JWT_SECRET=SUBSTITUIR_POR_SEGREDO_64_CARACTERES_ALEATORIOS
JWT_REFRESH_SECRET=SUBSTITUIR_POR_SEGREDO_64_CARACTERES_DIFERENTE
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_COST=12

# ============================================================================
# apps/api (Fastify)
# ============================================================================
API_PORT=4000
UPLOAD_MAX_BYTES=5242880

# ============================================================================
# apps/web (Next.js)
# ============================================================================
NEXT_PUBLIC_API_URL=https://plataforma.reboucasebulhoes.com.br/api
WEB_PORT=3000

# ============================================================================
# Integracao Anthropic (Claude)
# ============================================================================
ANTHROPIC_API_KEY=placeholder-substituir-em-producao
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=4096

# ============================================================================
# Integracao Z-API (WhatsApp)
# ============================================================================
ZAPI_INSTANCE_ID=placeholder
ZAPI_TOKEN=placeholder
ZAPI_CLIENT_TOKEN=placeholder
ZAPI_BASE_URL=https://api.z-api.io

# ============================================================================
# Backup (servico rb-backup com rclone + Google Drive)
# ============================================================================
# Remoto configurado previamente com `docker compose run --rm backup rclone config`.
# Formato: nome-remoto:caminho/da/pasta
RCLONE_REMOTE=gdrive:rb-plataforma/backups
BACKUP_PREFIXO=rb-plataforma
# Opcional: ID da chave GPG publica para criptografar os dumps antes do upload
GPG_PUBLIC_KEY_ID=

# ============================================================================
# Rate limit
# ============================================================================
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MIN=15
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW_MIN=1
RATE_LIMIT_IA_MAX=30
RATE_LIMIT_IA_WINDOW_MIN=60

# ============================================================================
# Traefik (email usado pelo ACME/Let's Encrypt)
# ============================================================================
TRAEFIK_ACME_EMAIL=ti@reboucasebulhoes.com.br

# ============================================================================
# Seed inicial
# ============================================================================
SEED_SOCIO_EMAIL=ricardo.bulhoes@reboucasebulhoes.com.br
SEED_SOCIO_SENHA=Trocar@Primeiro@Acesso1
SEED_GESTORA_EMAIL=larissa@reboucasebulhoes.com.br
SEED_GESTORA_SENHA=Trocar@Primeiro@Acesso1

# Versao do POP
POP_EST_VERSAO_ATUAL=1.0
